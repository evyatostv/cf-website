{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "clinic-flow.co.il" }],
      "destination": "https://www.clinic-flow.co.il/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/soon", "destination": "/soon.html" },
    { "source": "/(.*)", "destination": "/app-shell.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    }
  ]
}
